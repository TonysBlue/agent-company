[Unit]
Description=Agent Company platform engineering runner
After=local-fs.target agent-company-worker.service

[Service]
Type=simple
WorkingDirectory=%h/agent-company
Environment="HOME=%h"
Environment="PATH=%h/.npm-global/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="CODEX_SANDBOX=danger-full-access"
ExecStart=/usr/bin/env python3.11 -m agent_company.cli runner-run --executor-id company-platform-runner --owner "Company Platform Engineer" --capability platform --capability governance --poll-seconds 5
Restart=on-failure
RestartSec=5
TimeoutStopSec=20
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ProtectSystem=strict
ReadWritePaths=%h/agent-company/data %h/agent-company/logs %h/agent-company/evidence %h/agent-workspaces

[Install]
WantedBy=default.target
